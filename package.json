{
	"name": "ED-Starter",
	"version": "1.0.0",
	"description": "ED-Starter: Next.js & Sanity",
	"homepage": "https://enginedigital.com",
	"private": true,
	"packageManager": "pnpm@10.19.0",
	"engines": {
		"node": "^22.12.0",
		"pnpm": ">=10.19.0",
		"npm": "Please use pnpm instead of npm."
	},
	"scripts": {
		"preinstall": "npx only-allow pnpm",
		"build": "cd frontend && pnpm run build",
		"dev": "pnpm --parallel -r run dev",
		"dev:next": "pnpm run dev --workspace=frontend",
		"dev:studio": "pnpm run dev --workspace=studio",
		"typegen": "cd studio && pnpm typegen",
		"typecheck": "cd frontend && pnpm typecheck",
		"format": "biome format --fix && biome check --fix",
		"plop": "plop",
		"setup-env": "cp -i \"$PWD/.env.example.local\" \"$PWD/.env.local\" && ln \"$PWD/.env.local\" \"$PWD/frontend/.env.local\" && ln \"$PWD/.env.local\" \"$PWD/studio/.env.local\""
	},
	"devDependencies": {
		"@biomejs/biome": "^2.3.12",
		"plop": "^4.0.5"
	}
}
