{
	"name": "ED-Starter",
	"version": "1.0.0",
	"description": "ED-Starter: Next.js & Sanity",
	"homepage": "https://enginedigital.com",
	"private": true,
	"scripts": {
		"build": "cd frontend && pnpm run build",
		"dev": "pnpm --parallel -r run dev",
		"dev:next": "pnpm run dev --workspace=frontend",
		"dev:studio": "pnpm run dev --workspace=studio",
		"typegen": "cd studio && pnpm typegen",
		"typecheck": "cd frontend && pnpm typecheck",
		"format": "biome format --fix && biome check --fix",
		"plop": "plop"
	},
	"packageManager": "pnpm@10.19.0",
	"devDependencies": {
		"@biomejs/biome": "^2.3.12",
		"plop": "^4.0.5"
	}
}
