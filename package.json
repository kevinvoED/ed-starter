{
  "name": "ed-starter",
  "version": "1.0.0",
  "workspaces": [
    "studio",
    "frontend"
  ],
  "scripts": {
    "dev": "npm-run-all --parallel --print-label dev:*",
    "dev:next": "npm run dev --workspace=frontend",
    "dev:studio": "npm run dev --workspace=studio",
    "typegen": "npm-run-all --serial --print-label typegen:studio typegen:next",
    "typegen:next": "npm run typegen --workspace=frontend",
    "typegen:studio": "npm run typegen --workspace=studio",
    "format": "biome format --fix && biome check --fix",
    "lint": "npm run lint --workspace=frontend",
    "type-check": "npm run type-check --workspaces",
    "plop": "npx plop"
  },
  "devDependencies": {
    "@biomejs/biome": "2.2.4",
    "npm-run-all2": "^5.0.2",
    "plop": "^4.0.2"
  }
}
