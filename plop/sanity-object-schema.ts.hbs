import { ComponentIcon } from '@sanity/icons';

import { description, image, title } from '@/schemas/sharedFields';

import { defineField, defineType } from 'sanity';

// Remember to change the icon to suit your new schema

export const {{camelCase name}} = defineType({
  name: '{{camelCase name}}',
  title: '{{titleCase name}}',
  type: 'object',
  icon: ComponentIcon,
  fields: [
    defineField({
      ...title,
    }),
    defineField({
      ...description,
    }),
    defineField({
      ...image,
    }),
  ],
  preview: {
    select: {
      title: 'title',
    },
    prepare({ title }) {
      return {
        title: '{{titleCase name}}',
        subtitle: title || 'No title provided',
      };
    },
  },
});

