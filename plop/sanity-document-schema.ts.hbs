import { ComponentIcon } from "@sanity/icons";
import { description, image, seo, title } from "@/schemas/sharedFields";
import { defineField, defineType } from "sanity";

// Remember to change the icon to suit your new schema

export const {{camelCase name}} = defineType({
  name: "{{camelCase name}}",
  title: "{{titleCase name}}",
  type: "object",
  icon: ComponentIcon,
  groups: [
    { name: "content", title: "Content", default: true },
    { name: "seo", title: "SEO" },
  ],
  fields: [
    defineField({
      ...title,
      group: "content",
    }),
    defineField({
      ...description,
      group: "content",
    }),
    defineField({
      ...image,
      group: "content",
    }),
    defineField({
      ...seo,
      group: "seo",
    }),
  ],
  preview: {
    select: {
      title: "title",
    },
    prepare({ title }) {
      return {
        title: "{{titleCase name}}",
        subtitle: title || "No title provided",
      };
    },
  },
});
