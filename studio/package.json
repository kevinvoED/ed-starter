    "@sanity/orderable-document-list": "^1.4.2",
    "@sanity/preview-url-secret": "^4.0.2",
    "@sanity/table": "^2.0.0",
    "@sanity/ui": "^3.1.11",
    "@sanity/vision": "^5.6.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "es-toolkit": "^1.41.0",
    "lucide-react": "^0.525.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-player": "^3.4.0",
    "sanity": "^5.6.0",
