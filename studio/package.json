  "description": "ED Sanity Studio",
  "homepage": "https://enginedigital.com",
  "private": true,
  "scripts": {
    "dev": "NODE_NO_WARNINGS=1 sanity dev",
    "start": "sanity start",
    "build": "sanity build",
