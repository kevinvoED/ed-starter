{
  "name": "studio",
  "version": "1.0.0",
  "description": "ED Sanity Studio",
  "homepage": "https://enginedigital.com",
  "private": true,
  "engines": {
    "node": "^22.12.0",
    "pnpm": "~10.19.0",
    "npm": "Please use pnpm instead of npm."
  },
  "packageManager": "pnpm@10.19.0",
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "dev": "NODE_NO_WARNINGS=1 sanity dev",
    "start": "sanity start",
    "build": "sanity build",
    "deploy": "sanity deploy",
    "typegen": "rm -rf schema.json && NODE_NO_WARNINGS=1 sanity schema extract --enforce-required-fields && NODE_NO_WARNINGS=1 sanity typegen generate",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@portabletext/react": "^6.0.3",
    "@sanity/asset-utils": "^2.3.0",
    "@sanity/code-input": "^7.0.12",
    "@sanity/dashboard": "^5.0.1",
    "@sanity/icons": "^3.7.4",
    "@sanity/image-url": "^2.0.3",
    "@sanity/orderable-document-list": "^1.5.1",
    "@sanity/preview-url-secret": "^4.0.3",
    "@sanity/table": "^2.0.1",
    "@sanity/ui": "^3.1.14",
    "@sanity/vision": "^5.17.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "es-toolkit": "^1.45.1",
    "lucide-react": "^0.577.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-player": "^3.4.0",
    "sanity": "^5.17.1",
    "sanity-plugin-dashboard-widget-vercel": "^3.1.6",
    "sanity-plugin-iframe-pane": "^5.0.10",
    "sanity-plugin-media": "^4.1.1",
    "sanity-plugin-rich-table": "^1.1.0",
    "sanity-plugin-simpler-color-input": "^4.0.0",
    "styled-components": "^6.3.11",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@sanity/client": "^7.17.0",
    "@sanity/eslint-config-studio": "^6.0.0",
    "@sanity/types": "^5.17.1",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "dotenv": "^17.3.1",
    "eslint": "^10.0.3",
    "typescript": "^5.9.3"
  }
}
