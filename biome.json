{
	"$schema": "https://biomejs.dev/schemas/2.2.4/schema.json",
	"vcs": {
		"enabled": true,
		"clientKind": "git",
		"useIgnoreFile": true
	},
	"files": {
		"ignoreUnknown": false,
		"includes": [
			"**",
			"!.sanity",
			"!**/schema.json",
			"!**/sanity/types.ts",
			"!**/sanity-typegen.json"
		]
	},
	"formatter": {
		"enabled": true,
		"useEditorconfig": true,
		"formatWithErrors": true
	},
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true
		}
	},
	"assist": {
		"actions": {
			"source": {
				"organizeImports": {
					"level": "on",
					"options": {
						"groups": [
							{ "type": true, "source": ["**"] },
							["react", "react*", "*react", "*/react"],
							["@next", "@next/**", "next", "next/**", "next-*", "next-*/**"],
							[
								"@sanity/**",
								"class-variance-authority",
								"clean-react-props",
								"gsap",
								"@gsap/**",
								"lodash-es",
								"es-toolkit",
								"nuqs"
							],
							["!@/styles/**", ":ALIAS:", "@/**"],
							["@/components/**", "@components/**", "radix-ui/**"],
							["@utility/**", "./**"]
						]
					}
				}
			}
		}
	},
	"overrides": [
		{
			"includes": ["**/*.ts", "**/*.tsx", "**/*.js", "**/*.mjs", "**/*.cjs"],
			"linter": {
				"rules": {
					"correctness": {
						"noUndeclaredVariables": "off",
						"noUnusedVariables": "error",
						"noConstAssign": "off",
						"noGlobalObjectCalls": "off",
						"noInvalidConstructorSuper": "off",
						"noSetterReturn": "off",
						"noUnreachable": "off",
						"noUnreachableSuper": "off",
						"noInvalidBuiltinInstantiation": "off"
					},
					"style": {
						"noNonNullAssertion": "off",
						"useConst": "error"
					},
					"suspicious": {
						"noEmptyBlockStatements": "off",
						"noDuplicateClassMembers": "off",
						"noDuplicateObjectKeys": "off",
						"noDuplicateParameters": "off",
						"noFunctionAssign": "off",
						"noImportAssign": "off",
						"noRedeclare": "off",
						"noUnsafeNegation": "off",
						"useGetterReturn": "off",
						"noVar": "error"
					},
					"complexity": {
						"noArguments": "error"
					}
				}
			}
		},
		{
			"includes": ["frontend/app/globals.css"],
			"linter": {
				"rules": {
					"suspicious": {
						"noUnknownAtRules": "off"
					}
				}
			}
		}
	]
}
